# Example environment variables for production
# Copy this to .env and fill in the values

PORT=3000
NODE_ENV=production

# MongoDB Atlas Connection String
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>

# Redis Configuration
# If REDIS_URL is provided, it takes priority over individual host/port settings.
# For Upstash or secure connections, use rediss:// (with two 's')

# Option 1: Full URL (Recommended for Render/Upstash)
# REDIS_URL=rediss://default:your_password@your-endpoint.upstash.io:6379

# Option 2: Individual Parts (For local or simple setups)
REDIS_HOST=localhost
REDIS_PORT=6379

